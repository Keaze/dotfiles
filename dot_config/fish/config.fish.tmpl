source /usr/share/cachyos-fish-config/cachyos-config.fish
set -Ux EDITOR nvim

starship init fish | source
zoxide init fish | source
thefuck --alias | source

if status is-interactive
    tv init fish | source
    atuin init fish | source
end

abbr -a pacman "sudo pacman"
abbr -a pac "sudo pacman"
abbr -a pacu "sudo pacman -Syu"
abbr -a cd z
abbr -a vi nvim
abbr -a vim nvim
abbr -a chze "chezmoi edit"
abbr -a chza "chezmoi apply"
abbr -a chzadd "chezmoi add"
abbr -a chzu "chezmoi update"
abbr -a gll "git log --pretty=oneline"
abbr -a gs "git status"
abbr -a gd "git diff"
abbr -a ga "git add"
abbr -a gc "git commit"
abbr -a gp "git push"
abbr -a gco "git checkout"
abbr -a grb "git rebase"

# bat as cat replacement
abbr -a cat bat
abbr -a catp "bat -p"

# ripgrep
abbr -a rgs "rg --smart-case"
abbr -a rgh "rg --hidden"

# zoxide interactive
abbr -a zi "z -i"

# eza tree views
abbr -a tree "eza --tree"
abbr -a treea "eza --tree --all"
# overwrite greeting
# potentially disabling fastfetch
